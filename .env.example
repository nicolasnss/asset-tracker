# ============================================
# Asset Tracker - Configuração de Ambiente
# ============================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Altere os valores conforme seu ambiente
# 3. NUNCA faça commit do arquivo .env.local
# 4. Configure variáveis de ambiente no seu SO
#
# ============================================

# Database Configuration
# PostgreSQL Connection Details
DB_URL=jdbc:postgresql://localhost:5432/asset_db
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_segura_aqui

# Hibernate/JPA Configuration
HIBERNATE_SHOW_SQL=true
HIBERNATE_FORMAT_SQL=true

# Spring Boot Server Configuration
SERVER_PORT=8080

# Application Profile
# Valores: dev, test, prod
SPRING_PROFILES_ACTIVE=dev

# Logging
LOGGING_LEVEL_COM_NICOLAS=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_HIBERNATE=INFO

# Actuator (Health Check)
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

